# =============================================================================
#  Projetenne — Configuration On-Premise Docker
#  Copiez ce fichier :  cp .env.example .env
#  puis remplissez les valeurs avant de lancer : docker-compose up -d
# =============================================================================

# ── Base de données ──────────────────────────────────────────────────────────
DB_NAME=projetenne_db

# ── Sécurité JWT ─────────────────────────────────────────────────────────────
# OBLIGATOIRE : remplacez par une chaîne aléatoire d'au moins 32 caractères
# Exemple : openssl rand -hex 32
JWT_SECRET=changeme-super-secret-key-minimum-32-caracteres

# ── CORS ─────────────────────────────────────────────────────────────────────
# En production, restreignez à votre domaine, ex: https://ppm.monentreprise.fr
CORS_ORIGINS=*

# ── Port HTTP exposé (défaut : 80) ───────────────────────────────────────────
HTTP_PORT=80

# ── Tenant initial & Administrateur ──────────────────────────────────────────
# Ces valeurs sont utilisées UNE SEULE FOIS au premier démarrage pour initialiser
# le tenant et créer le compte administrateur.
# Après le premier démarrage, la modification de ces variables n'a plus d'effet.
TENANT_NAME=MonEntreprise
ADMIN_EMAIL=admin@monentreprise.fr
ADMIN_PASSWORD=ChangeMe2025!

# ── SMTP — Notifications email (optionnel) ────────────────────────────────────
# SMTP_HOST=smtp.monserveur.fr
# SMTP_PORT=587
# SMTP_USER=noreply@monentreprise.fr
# SMTP_PASSWORD=motdepasse
# SMTP_FROM=noreply@monentreprise.fr

# ── Intelligence Artificielle (optionnel) ────────────────────────────────────
# Clé Anthropic pour les fonctionnalités IA (à activer dans une version future)
# ANTHROPIC_API_KEY=sk-ant-...
